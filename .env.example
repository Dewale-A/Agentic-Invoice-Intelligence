# ============================================================
# AgenticInvoiceIntelligence - Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- OpenAI ----
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ---- Application ----
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0

# ---- Database ----
# Defaults to SQLite (src/data/invoice_intelligence.db).
# For production, set this to a PostgreSQL connection string.
DATABASE_URL=sqlite:///./src/data/invoice_intelligence.db

# ---- Governance thresholds (optional overrides) ----
OCR_CONFIDENCE_THRESHOLD=0.85
AGENT_CONFIDENCE_THRESHOLD=0.70
VARIANCE_THRESHOLD_PCT=0.10
MATERIALITY_L1=5000
MATERIALITY_L2=25000
MATERIALITY_L3=100000

# ---- Logging ----
LOG_LEVEL=INFO
